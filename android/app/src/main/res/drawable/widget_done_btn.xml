<?xml version="1.0" encoding="utf-8"?>
<!-- Done-button pill. The solid color is tinted at runtime (API 31+) to the
     user's accent; this default shows on older platforms / before tint. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FF4C6FFF" />
    <corners android:radius="18dp" />
</shape>
