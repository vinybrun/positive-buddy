<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- USE_EXACT_ALARM is auto-granted (no user dialog) and is the right
         permission for habit/medication reminders on Android 13+. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <!-- Fallback for Android 12 (which can't use USE_EXACT_ALARM) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <application
        android:label="Positive Buddy"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- v4/v15: activity-aliases the Dart layer toggles to swap the
             launcher icon. Exactly one is enabled at a time (or none → the
             default MainActivity icon). Static species (cat/dog/butterfly)
             get one alias each; evolving species (fox/snake/bird) get one
             per evolution stage (S1..S5) so the icon grows up with the
             buddy. All android:enabled="false" by default. The staged
             aliases are generated/kept in sync with ALIAS handling in
             MainActivity.kt. -->
        <activity-alias
            android:name=".MainActivityCat"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_cat"
            android:roundIcon="@mipmap/ic_launcher_cat"
            android:label="Positive Buddy"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivityDog"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_dog"
            android:roundIcon="@mipmap/ic_launcher_dog"
            android:label="Positive Buddy"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivityButterfly"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_butterfly"
            android:roundIcon="@mipmap/ic_launcher_butterfly"
            android:label="Positive Buddy"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <!-- STAGED-ALIASES-START : fox / snake / bird × stages 1-5 -->
        <activity-alias android:name=".MainActivityFoxS1" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_fox_s1" android:roundIcon="@mipmap/ic_launcher_fox_s1" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityFoxS2" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_fox_s2" android:roundIcon="@mipmap/ic_launcher_fox_s2" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityFoxS3" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_fox_s3" android:roundIcon="@mipmap/ic_launcher_fox_s3" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityFoxS4" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_fox_s4" android:roundIcon="@mipmap/ic_launcher_fox_s4" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityFoxS5" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_fox_s5" android:roundIcon="@mipmap/ic_launcher_fox_s5" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivitySnakeS1" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_snake_s1" android:roundIcon="@mipmap/ic_launcher_snake_s1" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivitySnakeS2" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_snake_s2" android:roundIcon="@mipmap/ic_launcher_snake_s2" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivitySnakeS3" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_snake_s3" android:roundIcon="@mipmap/ic_launcher_snake_s3" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivitySnakeS4" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_snake_s4" android:roundIcon="@mipmap/ic_launcher_snake_s4" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivitySnakeS5" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_snake_s5" android:roundIcon="@mipmap/ic_launcher_snake_s5" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityBirdS1" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_bird_s1" android:roundIcon="@mipmap/ic_launcher_bird_s1" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityBirdS2" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_bird_s2" android:roundIcon="@mipmap/ic_launcher_bird_s2" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityBirdS3" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_bird_s3" android:roundIcon="@mipmap/ic_launcher_bird_s3" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityBirdS4" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_bird_s4" android:roundIcon="@mipmap/ic_launcher_bird_s4" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <activity-alias android:name=".MainActivityBirdS5" android:enabled="false" android:exported="true" android:icon="@mipmap/ic_launcher_bird_s5" android:roundIcon="@mipmap/ic_launcher_bird_s5" android:label="Positive Buddy" android:targetActivity=".MainActivity">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter>
        </activity-alias>
        <!-- STAGED-ALIASES-END -->
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Home-screen widgets (home_widget). Each provider draws today's
             habit progress; the big one's Done buttons fire a background
             intent handled by HomeWidgetBackgroundReceiver → Dart. -->
        <!-- Declared tiny → small → big so launchers that honor manifest
             order list them that way in the widget picker. -->
        <receiver
            android:name=".TinyHabitWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_tiny_info" />
        </receiver>
        <receiver
            android:name=".SmallHabitWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_small_info" />
        </receiver>
        <receiver
            android:name=".BigHabitWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_big_info" />
        </receiver>
        <receiver
            android:name="es.antonborri.home_widget.HomeWidgetBackgroundReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.BACKGROUND" />
            </intent-filter>
        </receiver>

        <!-- flutter_local_notifications receivers -->
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ActionBroadcastReceiver" />
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver" />
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
